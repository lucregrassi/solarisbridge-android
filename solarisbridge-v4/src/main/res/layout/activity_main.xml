<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="@string/title_home"
        app:titleTextColor="?attr/colorOnSurface"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextureView
        android:id="@+id/videoTexture"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorSurface"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/videoTexture"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/controlPanelContent"
            android:layout_width="270dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvCommunicationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_communication"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSatelliteCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_satellites_placeholder"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVideo"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/button_start_video_stream"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/state_green"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/tvVideoStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:text="@string/status_video_stream_off"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/state_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTelemetry"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/button_start_telemetry_stream"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/state_green"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/tvTelemetryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:text="@string/status_telemetry_stream_off"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/state_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCmd"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/button_start_command_receiver"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/state_green"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/tvCmdStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/status_command_system_off"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/state_red" />

            <TextView
                android:id="@+id/tvCmdLast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="@string/status_last_command_placeholder"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnObstacleAvoidance"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/button_check_obstacle_avoidance"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/state_green"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/tvObstacleAvoidanceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/status_obstacle_avoidance_unknown"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/state_red" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>